{
  "name": "mrkapu-wall-service",
  "version": "0.0.1",
  "description": "Standalone wall service extracted from mrkapu-back-end",
  "author": "",
  "private": true,
  "packageManager": "yarn@1.22.21",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:lambda": "yarn build",
    "deploy:wall": "yarn build && npm install --force @img/sharp-linux-arm64 @img/sharp-libvips-linux-arm64 && rm -rf node_modules/@img/sharp-darwin-arm64 node_modules/@img/sharp-libvips-darwin-arm64 && serverless deploy",
    "deploy:lambda": "yarn deploy:wall",
    "remove:wall": "serverless remove",
    "remove:lambda": "yarn remove:wall",
    "offline": "yarn build && serverless offline",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:lambda": "node -e \"const { handler } = require('./dist/lambda'); handler({ rawPath: '/', requestContext: { http: { method: 'GET' } } }, {}, console.log).then(console.log).catch(console.error)\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-eventbridge": "^3.1027.0",
    "@aws-sdk/client-rekognition": "^3.1027.0",
    "@aws-sdk/client-s3": "^3.980.0",
    "@aws-sdk/credential-providers": "^3.1027.0",
    "@aws-sdk/s3-request-presigner": "^3.980.0",
    "@codegenie/serverless-express": "^4.17.1",
    "@img/sharp-libvips-linux-arm64": "^1.3.1",
    "@img/sharp-linux-arm64": "^0.34.5",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/platform-express": "^11.1.24",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "false": "^0.0.4",
    "mongoose": "^8.15.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@types/aws-lambda": "^8.10.161",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "serverless": "^4.34.0",
    "serverless-jetpack": "^0.11.2",
    "serverless-offline": "^14.4.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
